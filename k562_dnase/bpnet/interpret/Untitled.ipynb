      "Modules Release 4.1.1 (2018-02-17)\u001b[m\n",
      "Usage: module [options] [command] [args ...]\u001b[m\n",
      "\u001b[m\n",
      "Loading / Unloading commands:\u001b[m\n",
      "  add | load      modulefile [...]  Load modulefile(s)\u001b[m\n",
      "  rm | unload     modulefile [...]  Remove modulefile(s)\u001b[m\n",
      "  purge                             Unload all loaded modulefiles\u001b[m\n",
      "  reload | refresh                  Unload then load all loaded modulefiles\u001b[m\n",
      "  switch | swap   [mod1] mod2       Unload mod1 and load mod2\u001b[m\n",
      "\u001b[m\n",
      "Listing / Searching commands:\u001b[m\n",
      "  list            [-t|-l]           List loaded modules\u001b[m\n",
      "  avail   [-d|-L] [-t|-l] [mod ...] List all or matching available modules\u001b[m\n",
      "  aliases                           List all module aliases\u001b[m\n",
      "  whatis          [modulefile ...]  Print whatis information of modulefile(s)\u001b[m\n",
      "  apropos | keyword | search  str   Search all name and whatis containing str\u001b[m\n",
      "  is-loaded       [modulefile ...]  Test if any of the modulefile(s) are loaded\u001b[m\n",
      "  is-avail        modulefile [...]  Is any of the modulefile(s) available\u001b[m\n",
      "  info-loaded     modulefile        Get full name of matching loaded module(s)\u001b[m\n",
      "\u001b[m\n",
      "Collection of modules handling commands:\u001b[m\n",
      "  save            [collection|file] Save current module list to collection\u001b[m\n",
      "  restore         [collection|file] Restore module list from collection or file\u001b[m\n",
      "\u001b[K\u001b[?1l\u001b>\n"
